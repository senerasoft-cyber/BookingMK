# Copy this to backend/.env.production on the server and fill in real values.
# Never commit the filled-in file anywhere -- it holds production secrets.

# --- Core ---
FLASK_ENV=production
DATABASE_URL=postgresql+psycopg2://bukano:CHANGE_ME_DB_PASSWORD@postgres:5432/bukano
CORS_ORIGINS=https://bukano.net
FRONTEND_URL=https://bukano.net

# --- Auth ---
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# --- Verification / SMS providers ---
# Leave unset to keep using StubNotifier (logs codes, doesn't send real SMS).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=
ALLOWED_COUNTRY_CODES=389
DAILY_SMS_CAP=50

# --- Bot protection ---
# Leave unset to skip Turnstile verification entirely.
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=

# --- File storage ---
UPLOADS_DIR=instance/uploads
UPLOADS_BASE_URL=https://api.bukano.net/uploads

# --- Reminders ---
# MUST be false here: gunicorn runs multiple workers, and each would start its
# own scheduler and double-send reminders. Run `flask send-reminders` from an
# external cron job (e.g. a host crontab calling `docker compose exec backend
# flask --app wsgi.py send-reminders`) instead.
ENABLE_REMINDER_SCHEDULER=false
REMINDER_INTERVAL_MINUTES=1

# --- Subscriptions / billing ---
# Leave PADDLE_API_KEY unset until your Paddle account + domain verification
# are both done -- billing.py falls back to a stub provider until then.
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_SANDBOX=true
PADDLE_PRICE_ID_BASIC_MONTHLY=
PADDLE_PRICE_ID_BASIC_YEARLY=
PADDLE_PRICE_ID_MID_MONTHLY=
PADDLE_PRICE_ID_MID_YEARLY=
PADDLE_PRICE_ID_TOP_MONTHLY=
PADDLE_PRICE_ID_TOP_YEARLY=

# --- Mail (welcome email, password reset) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@bukano.net
