# --- Core (Milestone 1) ---
FLASK_ENV=development
# SQLite (default, zero setup):
DATABASE_URL=sqlite:///instance/dev.db
# Or Postgres via docker-compose:
# DATABASE_URL=postgresql+psycopg2://maceda:maceda@localhost:5432/maceda_booking
CORS_ORIGINS=http://localhost:5173

# --- Auth (Milestone 2) ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# --- Verification / SMS providers (Milestone 4) ---
# Leave all of these unset in dev: StubNotifier logs codes to the console
# and the API returns a dev_code field instead of sending anything. There's
# no Viber provider wired up yet either way (Twilio doesn't offer one) --
# the "viber" channel always behaves like a stub for now.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=
ALLOWED_COUNTRY_CODES=389
# Default daily verification-SMS cap for newly created businesses (each
# business's cap is then stored on its own row and can be changed per-business).
DAILY_SMS_CAP=50

# --- Bot protection (Milestone 4) ---
# Leave TURNSTILE_SECRET_KEY unset in dev: the backend skips verification
# entirely so the booking flow works without a real Turnstile site.
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=

# --- File storage (Milestone 5) ---
UPLOADS_DIR=instance/uploads
UPLOADS_BASE_URL=http://localhost:5000/uploads

# --- Reminders (Milestone 6) ---
# Runs an in-process scheduler that checks for due reminders every
# REMINDER_INTERVAL_MINUTES. On a multi-worker production deployment, set this
# to false (each worker would otherwise run its own scheduler and double-send)
# and run `flask send-reminders` from an external cron job instead.
ENABLE_REMINDER_SCHEDULER=true
REMINDER_INTERVAL_MINUTES=1

# --- Subscriptions / billing (Milestone 8) ---
# Leave PADDLE_API_KEY unset in dev: billing.py falls back to a stub provider
# that activates the chosen plan immediately with no real payment, so the
# whole paywall/tier-gating flow works without a Paddle account at all.
# To go live: sign up at https://www.paddle.com, create a sandbox account first
# (test everything there before switching PADDLE_SANDBOX=false), create one
# Product with a Monthly and a Yearly Price per plan in the Paddle dashboard,
# and paste their price IDs below. See README "Going live with billing" for
# the full step-by-step.
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_SANDBOX=true
PADDLE_PRICE_ID_BASIC_MONTHLY=
PADDLE_PRICE_ID_BASIC_YEARLY=
PADDLE_PRICE_ID_MID_MONTHLY=
PADDLE_PRICE_ID_MID_YEARLY=
PADDLE_PRICE_ID_TOP_MONTHLY=
PADDLE_PRICE_ID_TOP_YEARLY=
